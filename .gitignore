# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Build Output ─────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
out/

# ─── Environment & Secrets ────────────────────────────────────────────────────
# NEVER commit API keys, Supabase credentials, or tokens
.env
.env.*
!.env.example        # Allow a safe template to be committed
*.local

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Cache & Temp ─────────────────────────────────────────────────────────────
.cache/
.temp/
.tmp/
*.tmp
.vite/
tsconfig.tsbuildinfo

# ─── Testing & Coverage ───────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ─── OS Generated ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── IDEs & Editors ───────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json   # Allow recommended extensions list
!.vscode/settings.json     # Allow shared workspace settings
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*.kate-swp
.project
.settings/
.classpath

# ─── Vercel ───────────────────────────────────────────────────────────────────
.vercel

# ─── Package manager locks (keep only one) ────────────────────────────────────
# This project uses npm — ignore other lock files
yarn.lock
pnpm-lock.yaml
bun.lockb
